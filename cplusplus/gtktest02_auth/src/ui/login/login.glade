<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk+" version="3.0"/>
  <object class="GtkWindow" id="AuthWindow">
    <property name="title">Авторизация</property>
    <property name="default_width">400</property>
    <property name="default_height">300</property>
    <property name="window_position">center</property>
    <child>
      <object class="GtkBox">
        <property name="orientation">vertical</property>
        <property name="margin">20</property>
        <child>
          <object class="GtkLabel">
            <property name="label">Вход в систему</property>
            <property name="margin_bottom">20</property>
          </object>
        </child>
        <child>
          <object class="GtkEntry" id="EntryUsername">
            <property name="placeholder_text">Имя пользователя</property>
            <property name="margin_bottom">10</property>
          </object>
        </child>
        <child>
          <object class="GtkEntry" id="EntryPassword">
            <property name="placeholder_text">Пароль</property>
            <property name="visibility">false</property>
            <property name="margin_bottom">20</property>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="ButtonLogin">
            <property name="label">Войти</property>
            <property name="margin_bottom">10</property>
          </object>
        </child>
        <child>
          <object class="GtkLabel" id="LabelStatus">
            <property name="label"></property>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>