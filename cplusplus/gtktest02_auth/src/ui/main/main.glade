<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk+" version="3.0"/>
  <object class="GtkWindow" id="MainWindow">
    <property name="title">Главное окно</property>
    <property name="default_width">800</property>
    <property name="default_height">600</property>
    <property name="window_position">center</property>
    <child>
      <object class="GtkBox">
        <property name="orientation">vertical</property>
        <child>
          <object class="GtkMenuBar">
            <child>
              <object class="GtkMenuItem">
                <property name="label">Файл</property>
                <child>
                  <object class="GtkMenu">
                    <child>
                      <object class="GtkMenuItem" id="MenuItemQuit">
                        <property name="label">Выход</property>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="GtkMenuItem">
                <property name="label">Помощь</property>
                <child>
                  <object class="GtkMenu">
                    <child>
                      <object class="GtkMenuItem" id="MenuItemAbout">
                        <property name="label">О программе</property>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkLabel">
            <property name="label">Добро пожаловать в приложение!</property>
            <property name="margin">20</property>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>